# Turso (libSQL) database URL.
# Local development: file:./local.db
# Remote (Turso):   libsql://<your-db>-<your-org>.turso.io
DATABASE_URL="file:./local.db"

# Turso auth token — required for remote databases, empty for local file DBs.
DATABASE_AUTH_TOKEN=""

# Auth.js (NextAuth v5) secret used to sign JWT session tokens.
# Generate your own with: npx auth secret
# (or: openssl rand -base64 32)
AUTH_SECRET="generate-your-own-secret-here"

# Upstash Redis (for rate limiting). Optional — if unset, rate limiting is
# disabled and the app works normally. Create a free DB at upstash.com.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
