// Prisma schema for the Recipes app.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Recipe model.
//
// Modeling choice for `ingredients` / `steps` (both `string[]` in app code):
// SQLite has no native array type. We store each list as a JSON-encoded
// string in a TEXT column (`ingredientsJson` / `stepsJson`) and perform all
// (de)serialization INSIDE the repository (app/lib/recipe-repository.ts).
// The rest of the app never sees these JSON columns — the repository always
// maps rows back to the `Recipe` app type with real `string[]` fields.
//
// Why JSON-in-TEXT over child tables (Ingredient/Step rows): ingredients and
// steps are always read and written as whole ordered lists alongside their
// recipe, are never queried/filtered individually, and have no independent
// identity. JSON-in-TEXT keeps reads/writes to a single row (no joins, no
// ordering columns to maintain) and keeps the schema simple. If future
// requirements demand per-ingredient querying, they can be promoted to
// related tables without touching any caller (the mapping stays in the repo).
model Recipe {
  id          String   @id @default(cuid())
  title       String
  imageUrl    String
  description String?
  // JSON-encoded string[] — (de)serialized inside the repository only.
  ingredientsJson String
  stepsJson       String
  // FK to User.id. The field is kept named `authorId` so existing callers and
  // the repository mapping are unchanged; the `author` relation field is added
  // for Prisma to model the foreign key.
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  // Recipe visibility: PRIVATE (owner only), PUBLIC (listed on discover),
  // UNLISTED (accessible via direct link but not listed on discover),
  // FAMILY (visible to family members only).
  visibility  String   @default("PRIVATE")
  // When visibility === "FAMILY", familyId points to the family this recipe
  // is scoped to. onDelete: SetNull so if a family is deleted, recipes keep
  // existing but become orphaned (the deleteFamily action re-scopes them to
  // PRIVATE before deleting, so SetNull is a safety net).
  familyId    String?
  family      Family?  @relation(fields: [familyId], references: [id], onDelete: SetNull)
  // Total time to make the recipe, in minutes (optional).
  minutes     Int?
  // "Soul" fields: the story/memory behind the recipe and who it came from
  // (e.g. "Grandma Rosa"). Free-text, optional — this is what makes a recipe
  // an heirloom rather than just instructions.
  story       String?
  sourceName  String?
  // Lineage: when a recipe is saved/forked from another, this points at the
  // original recipe id (kept loose — no FK — so the copy survives if the
  // original is deleted). Powers "Saved from …" attribution.
  parentRecipeId String?
  createdAt   DateTime @default(now())

  favorites   Favorite[]
  shareLinks  ShareLink[]

  @@index([authorId])
  @@index([visibility])
  @@index([familyId])
}

// User model for authentication.
//
// Auth strategy: Better Auth (replaced Auth.js v5) with the email/password
// provider. Sessions are now DATABASE-backed (see `Session`) rather than
// stateless JWTs — this enables revocation/multi-device logout, with a signed
// cookie cache to avoid a DB round-trip on most requests. Better Auth requires
// the companion `Session`, `Account`, and `Verification` tables below.
//
// Better Auth accesses these via Prisma model accessors (prisma.user/session/
// account/verification), so the table names stay PascalCase (no @@map) and the
// existing Recipe/Family foreign keys to `User` are unaffected.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  // Legacy Auth.js bcrypt hash. Better Auth stores the credential password in
  // Account.password instead; this column is kept (now optional) only as the
  // source for the one-off backfill script and as a rollback safety net. It
  // can be dropped once the migration is confirmed in production.
  passwordHash String?
  // Better Auth fields.
  emailVerified Boolean @default(false)
  image         String?
  // Entitlement tier: "FREE" | "PREMIUM". Drives feature gates (authored-recipe
  // cap, family-member cap). No payment processor yet — the beta "Upgrade"
  // action just flips this flag, standing in for a future checkout.
  plan         String   @default("FREE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt @default(now())

  recipes       Recipe[]
  ownedFamilies Family[]       @relation("FamilyOwner")
  families      FamilyMember[] @relation("FamilyMembership")
  sessions      Session[]
  accounts      Account[]
  favorites     Favorite[]
}

// Better Auth: active sessions. A signed cookie cache (see app/lib/auth.ts)
// serves most reads without touching this table.
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Better Auth: per-provider account. For email/password the row has
// providerId "credential" and the bcrypt hash in `password`.
model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt @default(now())

  @@index([userId])
}

// Better Auth: short-lived verification tokens (email verify, password reset).
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt @default(now())

  @@index([identifier])
}

model Family {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation("FamilyOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  members   FamilyMember[]
  recipes   Recipe[]
  invites   FamilyInvite[]

  @@index([ownerId])
}

model FamilyMember {
  id        String   @id @default(cuid())
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("FamilyMembership", fields: [userId], references: [id], onDelete: Cascade)
  // SQLite has no native enum; stored as TEXT. Values: "OWNER" | "MEMBER".
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())

  @@unique([familyId, userId])
  @@index([userId])
}

// A user's favorited recipe. Favoriting is free and never counts against any
// cap — only recipes you AUTHOR count toward the free tier limit.
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, recipeId])
  @@index([userId])
  @@index([recipeId])
}

// A tokenized share link for the "friends" circle: anyone with the link can
// view the recipe via /r/<token>, regardless of its visibility. Revoking = deleting
// the row. createdById is denormalized (no FK) for a lightweight audit trail.
model ShareLink {
  id          String   @id @default(cuid())
  token       String   @unique
  recipeId    String
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdById String
  createdAt   DateTime @default(now())

  @@index([recipeId])
}

// A tokenized invite to join a family via /families/<id>/join?token=<token>.
// Single-use is enforced at accept time (idempotent membership upsert), and the
// link can be revoked by deleting the row.
model FamilyInvite {
  id          String   @id @default(cuid())
  token       String   @unique
  familyId    String
  family      Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  role        String   @default("MEMBER")
  createdById String
  createdAt   DateTime @default(now())

  @@index([familyId])
}
